<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_card">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pedidos"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnNotificaciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔"
            android:textSize="22sp"/>
    </LinearLayout>

    <!-- Tabs principales -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tabPeticiones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Peticiones"
            android:textColor="@color/accent_blue"
            android:textSize="15sp"
            android:gravity="center"
            android:paddingBottom="8dp"/>

        <TextView
            android:id="@+id/tabPedidosClientes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pedidos de clientes"
            android:textColor="@color/state_inactive"
            android:textSize="15sp"
            android:gravity="center"
            android:paddingBottom="8dp"/>
    </LinearLayout>

    <!-- Contenido: cambia entre las dos vistas -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Vista Peticiones -->
        <ScrollView
            android:id="@+id/viewPeticiones"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Peticiones de vendedores"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPeticiones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pedidos de clientes"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Resumen contadores -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:id="@+id/cardTodos"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center" android:background="@color/bg_avatar"
                        android:padding="10dp" android:layout_marginEnd="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Todos"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="156"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="18sp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/cardPendientes"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center" android:background="@color/bg_section"
                        android:padding="10dp" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pendientes" android:textColor="@color/state_pending" android:textSize="11sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="24" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/cardEnProceso"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center" android:background="@color/bg_section"
                        android:padding="10dp" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="En proceso" android:textColor="@color/accent_blue" android:textSize="11sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="48" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/cardCompletados"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center" android:background="@color/bg_section"
                        android:padding="10dp" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Completados" android:textColor="@color/state_active" android:textSize="11sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="72" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/cardCancelados"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center" android:background="@color/bg_section"
                        android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Cancelados" android:textColor="@color/state_cancelled" android:textSize="11sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="12" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- Vista Pedidos de clientes -->
        <LinearLayout
            android:id="@+id/viewPedidosClientes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="16dp">

            <!-- Buscador -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1E2D3D"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Buscar pedidos..."
                    android:textColorHint="@color/state_inactive"
                    android:textColor="@color/text_primary"
                    android:background="@null"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="18sp"/>
            </LinearLayout>

            <!-- Sub-tabs -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/subTabTodos"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Todos (156)" android:textColor="@color/text_primary"
                        android:background="@color/accent_blue" android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp" android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/subTabPendientes"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pendientes (24)" android:textColor="@color/state_inactive"
                        android:background="@color/bg_section" android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp" android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/subTabEnProceso"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="En proceso (48)" android:textColor="@color/state_inactive"
                        android:background="@color/bg_section" android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp" android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/subTabCancelados"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Cancelados (12)" android:textColor="@color/state_inactive"
                        android:background="@color/bg_section" android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPedidosClientes"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvFooter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mostrando 1-5 de 156 pedidos"
                android:textColor="@color/state_inactive"
                android:textSize="12sp"
                android:paddingTop="8dp"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>