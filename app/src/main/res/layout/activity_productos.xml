<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- TopBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="@color/bg_card">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mis Productos"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
        <ImageButton
            android:id="@+id/btnNotif"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_notifications"
            app:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- Tabs Todos / Activos / Inactivos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/tabTodos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Todos (56)"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:focusable="true"/>
        <TextView
            android:id="@+id/tabActivos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Activos (48)"
            android:textColor="@color/state_inactive"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:focusable="true"/>
        <TextView
            android:id="@+id/tabInactivos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Inactivos (8)"
            android:textColor="@color/state_inactive"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/tab_selector"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Buscador + filtro -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp">
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Buscar producto..."
            app:hintTextColor="@color/state_inactive"
            app:boxStrokeColor="@color/bg_input"
            app:boxBackgroundColor="@color/bg_card"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="@color/state_inactive"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            android:layout_marginEnd="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>
        <ImageButton
            android:id="@+id/btnFilter"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_filter"
            app:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- Botón Nuevo producto -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNuevoProducto"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="+ Nuevo producto"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:backgroundTint="@color/bg_btngreen"
        app:cornerRadius="10dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="10dp"/>

    <!-- Lista de productos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProductos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false"/>

</LinearLayout>