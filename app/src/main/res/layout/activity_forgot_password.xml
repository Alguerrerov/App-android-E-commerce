<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/text_primary">

    <!-- Header azul con ícono -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_icon">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_gear_wrench"
            app:tint="@color/text_primary"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olvidé mi contraseña"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Título y descripción -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recuperación de Contraseña"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresa tu correo electrónico y te enviaremos un enlace para reestablecer tu contraseña"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"/>

            <!-- Campo correo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correo Electrónico"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@android:drawable/edit_text"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✉ "
                    android:textSize="16sp"
                    android:textColor="@color/state_inactive"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Ejemplo de correo"
                    android:textColorHint="@color/text_tertiary"
                    android:inputType="textEmailAddress"
                    android:background="@null"/>
            </LinearLayout>

            <!-- Botón enviar -->
            <Button
                android:id="@+id/btnEnviar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Enviar enlace de recuperación"
                android:backgroundTint="@color/accent_blue"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Separador -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="o"
                android:textColor="@color/text_tertiary"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <!-- Botón volver -->
            <Button
                android:id="@+id/btnVolver"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Volver al inicio"
                android:backgroundTint="@color/bg_icon"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"/>

            <!-- Sección soporte -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No recuerdas tu correo o necesitas ayuda?"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/text_light"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎧"
                    android:textSize="32sp"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Puedes comunicarte con soporte para recuperar tu cuenta."
                        android:textColor="@color/text_darkgray"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvSoporte"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ir a soporte"
                        android:textColor="@color/accent_blue"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>