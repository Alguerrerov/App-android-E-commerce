<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TopBar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="#0D2137">
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Detalle de cliente"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Header cliente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="#0D2137">
            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_person"
                app:tint="#FFFFFF"
                android:background="#1E3A5F"
                android:padding="10dp"
                android:layout_marginEnd="12dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Juan Pérez"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/tvRol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cliente"
                        android:textColor="#1E90FF"
                        android:textSize="11sp"
                        android:background="#1A1E90FF"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="juanperez@gmail.com"
                    android:textColor="#8899AA"
                    android:textSize="12sp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/circle_green"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID: CLT-0001245"
                        android:textColor="#1E90FF"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Opciones CRUD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Editar información -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEditar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D2137"
                app:cardCornerRadius="10dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:background="#1A1E90FF"
                        android:layout_marginEnd="12dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_edit" app:tint="#1E90FF"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Editar información" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Modificar datos personales del cliente" android:textColor="#8899AA" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_arrow_right" app:tint="#8899AA"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Historial de pedidos -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardHistorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D2137"
                app:cardCornerRadius="10dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <LinearLayout android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#A4C639" android:layout_marginEnd="12dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_orders" app:tint="#4CAF50"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Historial de pedidos" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ver todos los pedidos realizados" android:textColor="#8899AA" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_arrow_right" app:tint="#8899AA"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Ver direcciones -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDirecciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D2137"
                app:cardCornerRadius="10dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <LinearLayout android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#FFFF00" android:layout_marginEnd="12dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_location" app:tint="#EF9F27"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ver direcciones" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gestionar direcciones guardadas" android:textColor="#8899AA" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_arrow_right" app:tint="#8899AA"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bloquear cliente -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBloquear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D2137"
                app:cardCornerRadius="10dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <LinearLayout android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#FFFFFF" android:layout_marginEnd="12dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_lock" app:tint="#E24B4A"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bloquear cliente" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Impedir que el cliente acceda a la app" android:textColor="#8899AA" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_arrow_right" app:tint="#8899AA"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Eliminar cliente -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEliminar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D2137"
                app:cardCornerRadius="10dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <LinearLayout android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#FF0000" android:layout_marginEnd="12dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_delete" app:tint="#E24B4A"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Eliminar cliente" android:textColor="#E24B4A" android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Eliminar cuenta y todos sus datos." android:textColor="#8899AA" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_arrow_right" app:tint="#8899AA"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Estado actual -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Estado actual" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D2137"
                app:cardCornerRadius="10dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Estado" android:textColor="#8899AA" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvEstadoActual" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Activo" android:textColor="#4CAF50" android:textSize="13sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvDescripcionEstado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="El cliente puede iniciar sesión y realizar compras con normalidad.\n\nSi bloqueas o eliminas al cliente, ya no podrá acceder a la aplicación."
                        android:textColor="#8899AA"
                        android:textSize="12sp"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>