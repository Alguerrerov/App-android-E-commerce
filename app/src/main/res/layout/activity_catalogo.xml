<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628">

    <!-- TopBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="#0D2137">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Catálogo"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
        <ImageButton
            android:id="@+id/btnFiltros"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_filter"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- Buscador -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Buscar productos..."
        app:hintTextColor="#8899AA"
        app:boxStrokeColor="#1E2A45"
        app:boxBackgroundColor="#0D2137"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="#8899AA"
        app:boxCornerRadiusTopStart="10dp"
        app:boxCornerRadiusTopEnd="10dp"
        app:boxCornerRadiusBottomStart="10dp"
        app:boxCornerRadiusBottomEnd="10dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:inputType="text"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Chips de filtros activos -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="8dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipTodos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Todos"
                android:textColor="#FFFFFF"
                app:chipBackgroundColor="#1E90FF"
                app:chipStrokeColor="#1E90FF"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipFiltros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filtros"
                android:textColor="#8899AA"
                app:chipBackgroundColor="#0D2137"
                app:chipStrokeColor="#1E2A45"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipFrenos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Frenos"
                android:textColor="#8899AA"
                app:chipBackgroundColor="#0D2137"
                app:chipStrokeColor="#1E2A45"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAceites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aceites"
                android:textColor="#8899AA"
                app:chipBackgroundColor="#0D2137"
                app:chipStrokeColor="#1E2A45"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipBaterias"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Baterías"
                android:textColor="#8899AA"
                app:chipBackgroundColor="#0D2137"
                app:chipStrokeColor="#1E2A45"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipSuspension"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suspensión"
                android:textColor="#8899AA"
                app:chipBackgroundColor="#0D2137"
                app:chipStrokeColor="#1E2A45"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Contador resultados -->
    <TextView
        android:id="@+id/tvResultados"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="56 productos encontrados"
        android:textColor="#8899AA"
        android:textSize="12sp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"/>

    <!-- Grid de productos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCatalogo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"/>

</LinearLayout>