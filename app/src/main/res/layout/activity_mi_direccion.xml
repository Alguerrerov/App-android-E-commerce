<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="@color/bg_card">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:gravity="center"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mi dirección"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Botón agregar -->
    <TextView
        android:id="@+id/tvAgregarDireccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Agregar dirección"
        android:textColor="@color/accent_blue"
        android:textSize="13sp"
        android:gravity="end"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Estado vacío -->
            <LinearLayout
                android:id="@+id/layoutVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="48dp"
                android:visibility="visible">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="48sp"
                    android:layout_marginBottom="12dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No tienes una dirección guardada"
                    android:textColor="@color/state_inactive"
                    android:textSize="14sp"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toca '+ Agregar dirección' para comenzar"
                    android:textColor="@color/state_inactive"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Card dirección guardada -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layoutDireccionCasa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="10dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título y badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📍 Dirección principal"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Predeterminada"
                            android:textColor="@color/accent_blue"
                            android:textSize="11sp"
                            android:background="@color/bg_bdg"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"/>
                    </LinearLayout>

                    <!-- Texto de la dirección -->
                    <TextView
                        android:id="@+id/tvDireccionCasa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/state_inactive"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Botones editar / eliminar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/btnEditarCasa"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@color/bg_item"
                            android:padding="10dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✏ Editar"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnEliminarCasa"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@color/bg_item"
                            android:padding="10dp"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🗑 Eliminar"
                                android:textColor="#E24B4A"
                                android:textSize="13sp"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Botón guardar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuardar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Listo"
        android:textColor="@color/text_primary"
        app:backgroundTint="@color/accent_blue"
        app:cornerRadius="10dp"
        android:layout_margin="16dp"/>

</LinearLayout>