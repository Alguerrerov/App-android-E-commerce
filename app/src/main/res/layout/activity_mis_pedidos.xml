<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mis pedidos"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text=""/>
    </LinearLayout>

    <!-- Tabs -->
    <HorizontalScrollView
        android:layout_width="343dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:paddingHorizontal="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tabTodos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="#1E90FF"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Todos"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tabPendientes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@color/bg_section"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Pendientes"
                android:textColor="@color/state_inactive" />

            <TextView
                android:id="@+id/tabEnviados"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@color/bg_section"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Enviados"
                android:textColor="@color/state_inactive" />

            <TextView
                android:id="@+id/tabEntregados"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@color/bg_section"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Entregados"
                android:textColor="@color/state_inactive" />

            <TextView
                android:id="@+id/tabCancelados"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:background="@color/bg_section"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Cancelados"
                android:textColor="@color/state_inactive" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Filtrar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="53dp"
        android:layout_marginBottom="8dp"
        android:gravity="end"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/btnFiltrar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/bg_section"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Filtrar ▼"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <!-- Lista pedidos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPedidos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"/>

</LinearLayout>