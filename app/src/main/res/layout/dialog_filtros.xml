<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_card"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filtrar productos"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Filtro Categoría -->
    <TextView android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Categoría"
        android:textColor="@color/accent_blue"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Todas las categorías"
        app:hintTextColor="@color/state_inactive" app:boxStrokeColor="@color/accent_blue"
        app:boxBackgroundColor="@color/bg_screen"
        app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
        android:layout_marginBottom="16dp">
        <AutoCompleteTextView
            android:id="@+id/spinnerCategoria"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="none"
            android:textColor="@color/text_primary"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Filtro Marca -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Marca"
        android:textColor="@color/accent_blue"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Todas las marcas"
        app:hintTextColor="@color/state_inactive" app:boxStrokeColor="@color/accent_blue"
        app:boxBackgroundColor="@color/bg_screen"
        app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
        android:layout_marginBottom="16dp">
        <AutoCompleteTextView
            android:id="@+id/spinnerMarca"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="none"
            android:textColor="@color/text_primary"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Filtro Precio -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rango de precio"
        android:textColor="@color/accent_blue"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Mínimo"
            app:hintTextColor="@color/state_inactive" app:boxStrokeColor="@color/accent_blue"
            app:boxBackgroundColor="@color/bg_screen"
            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
            android:layout_marginEnd="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrecioMin"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/state_inactive"
            android:layout_marginHorizontal="4dp"/>
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Máximo"
            app:hintTextColor="@color/state_inactive" app:boxStrokeColor="@color/accent_blue"
            app:boxBackgroundColor="@color/bg_screen"
            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
            android:layout_marginStart="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrecioMax"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Botones -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimpiar"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Limpiar"
            android:textColor="@color/state_inactive"
            app:strokeColor="@color/state_inactive"
            app:cornerRadius="8dp"
            android:layout_marginEnd="8dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAplicar"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Aplicar"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/accent_blue"
            app:cornerRadius="8dp"/>
    </LinearLayout>

</LinearLayout>