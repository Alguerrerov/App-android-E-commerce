<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628">

    <!-- Contenido principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0A1628">

        <!-- TopBar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="#0A1628">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_menu"
                app:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <!-- Logo -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginStart="8dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_gear_wrench"
                    app:tint="#1E90FF"
                    android:layout_marginEnd="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parts"
                    android:textColor="#1E90FF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnNotif"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_notifications"
                app:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <!-- Contenido scrolleable -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Banner promocional -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    app:cardBackgroundColor="#0D2137"
                    app:cardCornerRadius="0dp"
                    android:layout_marginBottom="16dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Imagen de fondo del banner -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="end"
                            android:alpha="0.6"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_brake_disc"
                            app:tint="#1E2A45" />

                        <!-- Texto banner -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="20dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FRENOS"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SEGURIDAD QUE\nTE PROTEGE"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:layout_marginBottom="12dp"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnVerMas"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="VER MÁS"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                app:backgroundTint="#1E90FF"
                                app:cornerRadius="6dp"/>
                        </LinearLayout>

                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <!-- Sección Categorías -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Categorías"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvVerCategorias"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ver todas"
                        android:textColor="#1E90FF"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Grid de categorías -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="20dp">

                    <!-- Categoría 1 -->
                    <LinearLayout
                        android:id="@+id/catFiltros"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_gear_wrench"
                            app:tint="#1E90FF"
                            android:background="#0D2137"
                            android:padding="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Filtros"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Categoría 2 -->
                    <LinearLayout
                        android:id="@+id/catBaterias"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_battery"
                            app:tint="#EF9F27"
                            android:background="#0D2137"
                            android:padding="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Baterías"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Categoría 3 -->
                    <LinearLayout
                        android:id="@+id/catSuspension"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_suspension"
                            app:tint="#4CAF50"
                            android:background="#0D2137"
                            android:padding="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Suspensión"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Categoría 4 -->
                    <LinearLayout
                        android:id="@+id/catAceites"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_oil"
                            app:tint="#E24B4A"
                            android:background="#0D2137"
                            android:padding="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aceites"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Sección Productos destacados -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Productos destacados"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvVerProductos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ver todos"
                        android:textColor="#1E90FF"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Grid productos destacados 2 columnas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="80dp">

                    <!-- Producto 1 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardProducto1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#0D2137"
                        app:cardCornerRadius="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="6dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="90dp"
                                android:src="@drawable/ic_products"
                                app:tint="#8899AA"
                                android:scaleType="centerInside"
                                android:background="#1E2A45"
                                android:layout_marginBottom="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Batería 12V 60Ah"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$320.900"
                                android:textColor="#1E90FF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⭐"
                                    android:textSize="11sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" 4.7"
                                    android:textColor="#EF9F27"
                                    android:textSize="11sp"/>
                            </LinearLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="En stock"
                                android:textColor="#4CAF50"
                                android:textSize="10sp"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Producto 2 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardProducto2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#0D2137"
                        app:cardCornerRadius="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="6dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="90dp"
                                android:src="@drawable/ic_products"
                                app:tint="#8899AA"
                                android:scaleType="centerInside"
                                android:background="#1E2A45"
                                android:layout_marginBottom="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Disco de Freno Ventilado Delantero"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$120.900"
                                android:textColor="#1E90FF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⭐"
                                    android:textSize="11sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" 4.9"
                                    android:textColor="#EF9F27"
                                    android:textSize="11sp"/>
                            </LinearLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="En stock"
                                android:textColor="#4CAF50"
                                android:textSize="10sp"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0D2137"
            app:itemIconTint="@drawable/bottom_nav_selector"
            app:itemTextColor="@drawable/bottom_nav_selector"
            app:menu="@menu/menu_cliente_bottom"/>

    </LinearLayout>

    <!-- Menú lateral -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0A1628"
        app:headerLayout="@layout/nav_header_cliente"
        app:menu="@menu/menu_cliente_nav"
        app:itemTextColor="#FFFFFF"
        app:itemIconTint="#8899AA"/>

</androidx.drawerlayout.widget.DrawerLayout>