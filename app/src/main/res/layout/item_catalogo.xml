<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Imagen -->
        <ImageView
            android:id="@+id/ivProducto"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:src="@drawable/ic_products"
            app:tint="@color/state_inactive"
            android:scaleType="centerInside"
            android:background="@color/bg_input"
            android:layout_marginBottom="8dp"/>

        <!-- Badge categoría -->
        <TextView
            android:id="@+id/tvCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filtros"
            android:textColor="@color/accent_blue"
            android:textSize="10sp"
            android:background="@color/bg_bdg"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:layout_marginBottom="4dp"/>

        <!-- Nombre -->
        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filtro de Aceite Mann W610/3"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="4dp"/>

        <!-- Marca -->
        <TextView
            android:id="@+id/tvMarca"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mann"
            android:textColor="@color/state_inactive"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <!-- Precio -->
        <TextView
            android:id="@+id/tvPrecio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$27.900"
            android:textColor="@color/accent_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <!-- Rating + stock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ "
                android:textSize="11sp"/>
            <TextView
                android:id="@+id/tvRating"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="4.7"
                android:textColor="@color/state_pending"
                android:textSize="11sp"/>
            <TextView
                android:id="@+id/tvStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En stock"
                android:textColor="@color/state_active"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Botón agregar al carrito -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAgregar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Agregar"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            app:backgroundTint="@color/accent_blue"
            app:cornerRadius="8dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>